{
  "regions": ["sin1"],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "app/**",
          "templates/**",
          "public/**",
          "hexa-logo.png"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    { "path": "/api/jobs/aria-sync", "schedule": "0 0 * * *" }
  ]
}
